library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity DFF is
    port(
        Q     : out std_logic;
        clk   : in std_logic;
        reset : in std_logic;
        D     : in std_logic
    );
end DFF;

architecture Dataflow of DFF is

signal q_int : std_logic := '0';

begin

Q <= q_int;

q_int <= '0' when reset = '1' else D;

end Dataflow;
